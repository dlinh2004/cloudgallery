# ==========================================
# CẤU HÌNH ỨNG DỤNG (Application Config)
# ==========================================
PORT=3000
SESSION_SECRET=your-secret-key-here

# ==========================================
# CẤU HÌNH DATABASE - LOCAL (PostgreSQL Local)
# ==========================================
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=cloud_gallery
DB_PORT=5432

# ==========================================
# CẤU HÌNH LƯU TRỮ (Storage Mode)
# ==========================================
# Đặt "local" khi chạy trên máy local
# Đặt "s3" khi triển khai lên AWS
STORAGE_MODE=local

# ==========================================
# CẤU HÌNH AWS S3 (chỉ cần khi STORAGE_MODE=s3)
# ==========================================
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
# Nếu chạy trên EC2 với IAM Role, KHÔNG cần khai báo key
# Chỉ khai báo key khi chạy từ máy local muốn test S3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
